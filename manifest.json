{
  "name": "fastpic_redirect",
  "version": "1.0",
  "description": "Skip spam and view the full image on fastpic image hosting",
  "permissions": ["webNavigation"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "icons": {
    "128": "icons/on.png"
  },
  "action": {
    "default_icon": "icons/on.png",
    "default_title": "fastpic redirect"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.fastpic.org/fullview/*",
        "*://*.fastpic.ru/fullview/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "manifest_version": 3
}
